<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:mongodb="http://www.liquibase.org/xml/ns/mongodb"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
         http://www.liquibase.org/xml/ns/mongodb
         https://www.liquibase.org/xml/ns/mongodb/liquibase-mongodb-latest.xsd">

    <changeSet id="dropcollection" author="yaboi">
        <mongodb:dropCollection collectionName="users"/>
    </changeSet>
    <changeSet id="createcollection" author="yaboi">
        <mongodb:createCollection collectionName="users">
            <mongodb:options>
                <![CDATA[
{
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "required": ["name", "email"],
            "properties": {
                "name": {
                    "bsonType": "string"
                },
                "email": {
                    "bsonType": "string"
                },
                "createdDate": {
                    "bsonType": "date"
                },
                "lastModifiedDate": {
                    "bsonType": "date"
                }
            }
        }
    }
}
]]>
                </mongodb:options>
        </mongodb:createCollection>
    </changeSet>

</databaseChangeLog>